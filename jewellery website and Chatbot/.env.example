# PostgreSQL connection URL (e.g. from Neon, Supabase, or a local instance)
# Make sure pgvector extension is enabled in your database
DATABASE_URL=postgresql://username:password@localhost:5432/database_name

# Groq API Key for the Chatbot LLM (get from Groq Console: https://console.groq.com/)
GROQ_API_KEY=your_groq_api_key_here

# Gemini API Key for RAG Vector Embeddings (get from Google AI Studio: https://aistudio.google.com/)
GEMINI_API_KEY=your_gemini_api_key_here

# Webhook URL to push captured client leads to Google Sheets / CRM (Zapier, Make, HubSpot, etc.)
LEAD_WEBHOOK_URL=your_webhook_url_here

# Twilio WhatsApp Configuration (To send actual WhatsApp messages on price drops/offers)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Resend Email Configuration (To send actual email alerts on price drops/offers)
RESEND_API_KEY=re_your_resend_api_key_here

# Telegram Bot Configuration (To send actual Telegram alerts on price drops/offers)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

